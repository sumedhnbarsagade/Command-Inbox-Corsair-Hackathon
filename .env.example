# Since the ".env" file is gitignored, you can use the ".env.example" file to
# build a new ".env" file when you clone the repo. Keep this file up-to-date
# when you add new variables to `.env`.

# When adding additional environment variables, the schema in "/src/env.js"
# should be updated accordingly.

# =============================================================================
# REQUIRED (local dev + production deploy — Vercel/Netlify/etc.)
# Build fails with "Invalid environment variables" if these are missing.
# =============================================================================

# Drizzle / PostgreSQL (use Neon, Supabase, Vercel Postgres, or Railway in prod)
DATABASE_URL="postgresql://postgres:password@localhost:5432/google-demo"

# Corsair encryption key (generate with: openssl rand -base64 32)
# IMPORTANT: Keep the same value forever in prod, or reset corsair DB tables.
CORSAIR_KEK="your-corsair-key"

# =============================================================================
# RECOMMENDED
# =============================================================================

TENANT_ID="dev"

# Google OAuth — required for Gmail/Calendar sign-in & sync
GOOGLE_CLIENT_ID="your-google-client-id-here"
GOOGLE_CLIENT_SECRET="your-google-client-secret-here"

# LLM for agent chat & email prioritization (at least one recommended)
GEMINI_API_KEY="your-gemini-key"
# GOOGLE_GENERATIVE_AI_API_KEY=""  # alias used by @ai-sdk/google
# OPENAI_API_KEY=""

# =============================================================================
# VERCEL / PRODUCTION CHECKLIST
# =============================================================================
# 1. Project → Settings → Environment Variables → add ALL required vars above
# 2. Google Cloud Console → OAuth client → Authorized redirect URI:
#      https://YOUR-DOMAIN.vercel.app/api/auth/callback
# 3. After first deploy, run migrations against prod DB:
#      DATABASE_URL="your-prod-url" pnpm db:push
# 4. Redeploy after adding env vars (Vercel does not read local .env)
